rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    match /admins/{email} {
      allow read, write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }

    match /checkins/{checkinId} {
      allow create: if request.auth == null;
      allow read: if isAdmin() || request.auth == null;
    }

    // Per-event check-in counter for atomic team assignment.
    // Anyone may read it and increment it by exactly 1 (nothing else), so
    // simultaneous check-ins serialise and can't be tampered to arbitrary values.
    match /counters/{eventId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count == 1;
      allow update: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count == resource.data.count + 1;
    }
  }
}
